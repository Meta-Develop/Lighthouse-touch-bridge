<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Ltb.Gui.ViewModels"
        x:Class="Ltb.Gui.MainWindow"
        x:DataType="vm:InternalDriverViewModel"
        Title="Lighthouse Touch Bridge - Internal Driver"
        Width="1040"
        Height="860"
        MinWidth="760"
        MinHeight="620">
  <DockPanel Margin="16">
    <Border DockPanel.Dock="Bottom"
            Margin="0,12,0,0"
            Padding="10"
            BorderBrush="Gray"
            BorderThickness="1"
            CornerRadius="4">
      <Grid ColumnDefinitions="*,Auto" ColumnSpacing="16">
        <TextBlock x:Name="LegacyNotice"
                   VerticalAlignment="Center"
                   Text="Unsupported compile-only migration code: the legacy ALVR / VMT / TrackingOverrides wizard is not used by Start."
                   TextWrapping="Wrap" />
        <Button x:Name="ActionButton"
                Grid.Column="1"
                MinWidth="112"
                Content="{Binding ActionButtonText}"
                Command="{Binding ActionCommand}" />
      </Grid>
    </Border>

    <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                  VerticalScrollBarVisibility="Auto">
      <StackPanel Spacing="12">
        <TextBlock FontSize="26"
                   FontWeight="Bold"
                   Text="First-party internal driver" />

        <Border Padding="12"
                BorderBrush="Gray"
                BorderThickness="1"
                CornerRadius="4">
          <StackPanel Spacing="5">
            <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10">
              <TextBlock FontWeight="Bold" Text="Current phase" />
              <TextBlock x:Name="PhaseText"
                         Grid.Column="1"
                         FontSize="20"
                         FontWeight="Bold"
                         Text="{Binding PhaseText}" />
              <TextBlock x:Name="OverallStatusText"
                         Grid.Column="2"
                         FontWeight="Bold"
                         Text="{Binding OverallStatus}" />
            </Grid>
            <TextBlock x:Name="DiagnosticText"
                       Text="{Binding Diagnostic}"
                       TextWrapping="Wrap" />
            <TextBlock x:Name="RemediationText"
                       FontStyle="Italic"
                       Text="{Binding Remediation}"
                       TextWrapping="Wrap" />
            <TextBlock x:Name="RestartRequiredText"
                       FontWeight="Bold"
                       IsVisible="{Binding RestartRequired}"
                       Text="SteamVR restart required before readiness can pass." />
            <TextBlock x:Name="LastErrorText"
                       Text="{Binding LastError, StringFormat='Last error: {0}'}"
                       TextWrapping="Wrap" />
          </StackPanel>
        </Border>

        <Border Padding="10"
                BorderBrush="Gray"
                BorderThickness="1"
                CornerRadius="4">
          <StackPanel Spacing="6">
            <TextBlock FontSize="18" FontWeight="Bold" Text="Readiness" />
            <ListBox x:Name="ReadinessList"
                     ItemsSource="{Binding ReadinessRows}">
              <ListBox.ItemTemplate>
                <DataTemplate x:DataType="vm:ReadinessRowViewModel">
                  <Grid ColumnDefinitions="190,120,*"
                        ColumnSpacing="10"
                        Margin="2,3">
                    <TextBlock FontWeight="Bold" Text="{Binding Title}" />
                    <TextBlock Grid.Column="1" Text="{Binding Status}" />
                    <TextBlock Grid.Column="2"
                               Text="{Binding Detail}"
                               TextWrapping="Wrap" />
                  </Grid>
                </DataTemplate>
              </ListBox.ItemTemplate>
            </ListBox>
          </StackPanel>
        </Border>

        <Grid ColumnDefinitions="*,12,*">
          <Border Grid.Column="0"
                  Padding="10"
                  BorderBrush="Gray"
                  BorderThickness="1"
                  CornerRadius="4">
            <StackPanel Spacing="4">
              <TextBlock FontSize="18" FontWeight="Bold" Text="{Binding LeftHand.Title}" />
              <TextBlock x:Name="LeftTrackerText"
                         Text="{Binding LeftHand.TrackerSerial, StringFormat='Tracker: {0}'}" />
              <TextBlock Text="{Binding LeftHand.TrackerStatus, StringFormat='Tracker state: {0}'}" />
              <TextBlock x:Name="LeftPoseText"
                         Text="{Binding LeftHand.PoseStatus, StringFormat='Pose: {0}'}" />
              <TextBlock Text="{Binding LeftHand.PoseAge, StringFormat='Pose age: {0}'}" />
              <TextBlock Text="{Binding LeftHand.InputStatus, StringFormat='Input: {0}'}" />
              <TextBlock Text="{Binding LeftHand.ProfileStatus, StringFormat='Profile: {0}'}" />
              <TextBlock Text="{Binding LeftHand.PublishingStatus, StringFormat='Output: {0}'}" />
              <TextBlock x:Name="LeftNeutralReasonText"
                         Text="{Binding LeftHand.NeutralReason, StringFormat='Neutral reason: {0}'}"
                         TextWrapping="Wrap" />
              <TextBlock FontWeight="Bold" Text="Calibration evidence" />
              <TextBlock x:Name="LeftCalibrationModeText"
                         Text="{Binding LeftHand.CalibrationMode, StringFormat='Mode: {0}'}"
                         TextWrapping="Wrap" />
              <TextBlock x:Name="LeftCalibrationReasonText"
                         Text="{Binding LeftHand.CalibrationReason, StringFormat='Selection reason: {0}'}"
                         TextWrapping="Wrap" />
              <TextBlock x:Name="LeftCalibrationLagText"
                         Text="{Binding LeftHand.CalibrationLag, StringFormat='Estimated lag: {0}'}" />
              <TextBlock x:Name="LeftCalibrationQualityText"
                         Text="{Binding LeftHand.CalibrationQuality, StringFormat='Quality: {0}'}"
                         TextWrapping="Wrap" />
              <TextBlock x:Name="LeftCalibrationCreatedText"
                         Text="{Binding LeftHand.CalibrationCreated, StringFormat='Created: {0}'}" />
              <TextBlock FontWeight="Bold" Text="Capture evidence" />
              <TextBlock x:Name="LeftCaptureSamplesText"
                         Text="{Binding LeftHand.CaptureSamples, StringFormat='Samples: {0}'}" />
              <TextBlock x:Name="LeftCaptureValidityText"
                         Text="{Binding LeftHand.CaptureValidity, StringFormat='Validity: {0}'}"
                         TextWrapping="Wrap" />
              <TextBlock x:Name="LeftCaptureMotionText"
                         Text="{Binding LeftHand.CaptureMotion, StringFormat='Motion: {0}'}"
                         TextWrapping="Wrap" />
              <TextBlock Text="Rotation progress" />
              <ProgressBar x:Name="LeftRotationProgress"
                           Minimum="0"
                           Maximum="1"
                           Value="{Binding LeftHand.RotationProgress}" />
              <TextBlock x:Name="LeftRotationProgressText"
                         Text="{Binding LeftHand.RotationProgressStatus}" />
              <TextBlock Text="Position progress" />
              <ProgressBar x:Name="LeftPositionProgress"
                           Minimum="0"
                           Maximum="1"
                           Value="{Binding LeftHand.PositionProgress}" />
              <TextBlock x:Name="LeftPositionProgressText"
                         Text="{Binding LeftHand.PositionProgressStatus}" />
              <TextBlock Text="{Binding LeftHand.Diagnostic}"
                         TextWrapping="Wrap" />
            </StackPanel>
          </Border>

          <Border Grid.Column="2"
                  Padding="10"
                  BorderBrush="Gray"
                  BorderThickness="1"
                  CornerRadius="4">
            <StackPanel Spacing="4">
              <TextBlock FontSize="18" FontWeight="Bold" Text="{Binding RightHand.Title}" />
              <TextBlock x:Name="RightTrackerText"
                         Text="{Binding RightHand.TrackerSerial, StringFormat='Tracker: {0}'}" />
              <TextBlock Text="{Binding RightHand.TrackerStatus, StringFormat='Tracker state: {0}'}" />
              <TextBlock x:Name="RightPoseText"
                         Text="{Binding RightHand.PoseStatus, StringFormat='Pose: {0}'}" />
              <TextBlock Text="{Binding RightHand.PoseAge, StringFormat='Pose age: {0}'}" />
              <TextBlock Text="{Binding RightHand.InputStatus, StringFormat='Input: {0}'}" />
              <TextBlock Text="{Binding RightHand.ProfileStatus, StringFormat='Profile: {0}'}" />
              <TextBlock Text="{Binding RightHand.PublishingStatus, StringFormat='Output: {0}'}" />
              <TextBlock x:Name="RightNeutralReasonText"
                         Text="{Binding RightHand.NeutralReason, StringFormat='Neutral reason: {0}'}"
                         TextWrapping="Wrap" />
              <TextBlock FontWeight="Bold" Text="Calibration evidence" />
              <TextBlock x:Name="RightCalibrationModeText"
                         Text="{Binding RightHand.CalibrationMode, StringFormat='Mode: {0}'}"
                         TextWrapping="Wrap" />
              <TextBlock x:Name="RightCalibrationReasonText"
                         Text="{Binding RightHand.CalibrationReason, StringFormat='Selection reason: {0}'}"
                         TextWrapping="Wrap" />
              <TextBlock x:Name="RightCalibrationLagText"
                         Text="{Binding RightHand.CalibrationLag, StringFormat='Estimated lag: {0}'}" />
              <TextBlock x:Name="RightCalibrationQualityText"
                         Text="{Binding RightHand.CalibrationQuality, StringFormat='Quality: {0}'}"
                         TextWrapping="Wrap" />
              <TextBlock x:Name="RightCalibrationCreatedText"
                         Text="{Binding RightHand.CalibrationCreated, StringFormat='Created: {0}'}" />
              <TextBlock FontWeight="Bold" Text="Capture evidence" />
              <TextBlock x:Name="RightCaptureSamplesText"
                         Text="{Binding RightHand.CaptureSamples, StringFormat='Samples: {0}'}" />
              <TextBlock x:Name="RightCaptureValidityText"
                         Text="{Binding RightHand.CaptureValidity, StringFormat='Validity: {0}'}"
                         TextWrapping="Wrap" />
              <TextBlock x:Name="RightCaptureMotionText"
                         Text="{Binding RightHand.CaptureMotion, StringFormat='Motion: {0}'}"
                         TextWrapping="Wrap" />
              <TextBlock Text="Rotation progress" />
              <ProgressBar x:Name="RightRotationProgress"
                           Minimum="0"
                           Maximum="1"
                           Value="{Binding RightHand.RotationProgress}" />
              <TextBlock x:Name="RightRotationProgressText"
                         Text="{Binding RightHand.RotationProgressStatus}" />
              <TextBlock Text="Position progress" />
              <ProgressBar x:Name="RightPositionProgress"
                           Minimum="0"
                           Maximum="1"
                           Value="{Binding RightHand.PositionProgress}" />
              <TextBlock x:Name="RightPositionProgressText"
                         Text="{Binding RightHand.PositionProgressStatus}" />
              <TextBlock Text="{Binding RightHand.Diagnostic}"
                         TextWrapping="Wrap" />
            </StackPanel>
          </Border>
        </Grid>

        <Border Padding="10"
                BorderBrush="Gray"
                BorderThickness="1"
                CornerRadius="4">
          <StackPanel Spacing="4">
            <TextBlock FontSize="18" FontWeight="Bold" Text="Driver feed health" />
            <Grid ColumnDefinitions="160,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto"
                  ColumnSpacing="10" RowSpacing="3">
              <TextBlock Grid.Row="0" Text="State" />
              <TextBlock x:Name="FeedStateText" Grid.Row="0" Grid.Column="1" Text="{Binding FeedState}" />
              <TextBlock Grid.Row="1" Text="Session" />
              <TextBlock x:Name="FeedSessionText"
                         Grid.Row="1" Grid.Column="1" Text="{Binding FeedSession}" />
              <TextBlock Grid.Row="2" Text="Sequence" />
              <TextBlock x:Name="FeedSequenceText"
                         Grid.Row="2" Grid.Column="1" Text="{Binding FeedSequence}" />
              <TextBlock Grid.Row="3" Text="Heartbeat age" />
              <TextBlock x:Name="FeedHeartbeatText"
                         Grid.Row="3" Grid.Column="1" Text="{Binding FeedHeartbeatAge}" />
              <TextBlock Grid.Row="4" Text="Last send age" />
              <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding FeedSendAge}" />
              <TextBlock Grid.Row="5" Text="Reconnect attempts" />
              <TextBlock x:Name="FeedReconnectText"
                         Grid.Row="5" Grid.Column="1" Text="{Binding FeedReconnectAttempts}" />
              <TextBlock Grid.Row="6" Text="Error" />
              <TextBlock x:Name="FeedErrorText"
                         Grid.Row="6"
                         Grid.Column="1"
                         Text="{Binding FeedError}"
                         TextWrapping="Wrap" />
            </Grid>
          </StackPanel>
        </Border>
      </StackPanel>
    </ScrollViewer>
  </DockPanel>
</Window>
